# Native App Environment Variables
# Copy this file to .env and fill in your values

# URL of the backend server
# - iOS Simulator / Android Emulator on the same host: http://localhost:3000
# - Physical device on same LAN: replace localhost with this machine's LAN IP
#   (run `hostname -I` / `ipconfig getifaddr en0` to find it)
# - Cloud / prod: use https://your-server-url
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# LiveKit WebSocket URL
# - iOS Simulator / Android Emulator on the same host: ws://localhost:7880
# - Physical device on same LAN: replace localhost with this machine's LAN IP
# - Cloud / prod: use wss://livekit.your-host
EXPO_PUBLIC_LIVEKIT_URL=ws://localhost:7880
