# Server Environment Variables
# Copy this file to .env and fill in your values

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3001

# Google Generative AI (for AI chat feature)
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/community

# LiveKit (see docker/livekit/docker-compose.yml)
# Server SDK talks to the HTTP API for token validation, then uses the
# wss:// scheme for live signaling. Keep the http:// scheme here.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-to-your-livekit-api-secret
LIVEKIT_URL=http://localhost:7880
