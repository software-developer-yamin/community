{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "better-t-stack": {
      "type": "local",
      "command": ["pnpm", "dlx", "create-better-t-stack@latest", "mcp"],
      "enabled": true,
      "environment": {}
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "environment": {}
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true,
      "environment": {}
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "environment": {}
    },
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.inkeep.com/better-auth/mcp",
      "enabled": true
    },
    "expo-mcp": {
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "enabled": true
    },
    "livekit-docs": {
      "type": "remote",
      "url": "https://docs.livekit.io/mcp",
      "enabled": true
    },
    "ui-ux-pro": {
      "type": "local",
      "command": ["npx", "-y", "ui-ux-pro-mcp", "--stdio"]
    }
  }
}
